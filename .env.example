# Easypanel / Docker Compose environment variables
# Copy values into Easypanel → Compose Service → Environment → "Create .env file"

DB_NAME=test_database
CORS_ORIGINS=*
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
